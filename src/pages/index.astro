---
// ══════════════════════════════════════════════
//  EDIT YOUR TEXT HERE (only change words in quotes)
// ══════════════════════════════════════════════
const name     = "Kedarnath H";
const tagline   = "Financial Analyst · FP&A · Equity Research";
const headline  = "I turn financial data into clear, defensible decisions.";
const subhead   = "MBA in Finance · SEBI NISM certified. I build valuation models, equity research, and Power BI dashboards that turn raw data into decisions leaders can act on.";
const proof     = ["10-Year Multi-Asset Study", "CAMEL Bank Analysis", "ITC Sell-Side Initiation"];
const email     = "kedarnathgshm@gmail.com";
const github     = "https://github.com/Kedarnath-H";
const linkedin   = "https://www.linkedin.com/in/mrkedar";

const resumeReady = false;          // ← change to true AFTER you upload resume.pdf
const resumeFile  = "/resume.pdf";
// ══════════════════════════════════════════════
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{name} — {tagline}</title>
    <meta name="description" content={subhead} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="hero">
      <div class="hero__inner">
        <span class="status"><span class="dot"></span>Open to Financial Analyst / FP&A roles</span>
        <p class="tagline">{tagline}</p>
        <h1 class="name">{name}</h1>
        <h2 class="headline">{headline}</h2>
        <p class="subhead">{subhead}</p>

        <ul class="proof">
          {proof.map((p) => <li>{p}</li>)}
        </ul>

        <div class="cta">
          <a class="btn btn--primary" href={github} target="_blank" rel="noopener">View my work</a>
          {resumeReady && <a class="btn btn--ghost" href={resumeFile} target="_blank" rel="noopener">Download Resume</a>}
          <a class="btn btn--ghost" href={`mailto:${email}`}>Get in touch</a>
        </div>

        <div class="social">
          <a href={linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={github} target="_blank" rel="noopener">GitHub</a>
          <a href={`mailto:${email}`}>Email</a>
        </div>
      </div>
    </main>

    <style>
      /* ---- DESIGN TOKENS (single source of colour/type) ---- */
      :root {
        --bg:        #0a0e1a;
        --surface:   #111827;
        --text:      #f8fafc;
        --muted:     #94a3b8;
        --accent:    #10b981;   /* emerald = positive */
        --negative:  #ef4444;   /* red = negative only */
        --border:    rgba(255,255,255,0.08);
        --font:      'Inter', system-ui, sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: var(--font);
        color: var(--text);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }
      .hero {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 6vh 6vw;
        background:
          radial-gradient(70% 55% at 50% 0%, rgba(16,185,129,0.10), transparent 70%),
          var(--bg);
      }
      .hero__inner {
        max-width: 760px;
        animation: rise 0.7s ease both;
      }
      @keyframes rise { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }

      .status {
        display: inline-flex; align-items: center; gap: 8px;
        font-size: 0.82rem; font-weight: 500; color: var(--muted);
        border: 1px solid var(--border); border-radius: 999px;
        padding: 6px 14px; margin-bottom: 28px;
      }
      .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 4px rgba(16,185,129,0.15); }

      .tagline { color: var(--accent); font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; font-size: 0.8rem; margin-bottom: 14px; }
      .name { font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.05; }
      .headline { font-size: clamp(1.15rem, 2.6vw, 1.7rem); font-weight: 600; color: var(--text); margin: 18px 0 0; line-height: 1.3; }
      .subhead { font-size: clamp(1rem, 1.6vw, 1.12rem); color: var(--muted); margin-top: 20px; max-width: 620px; line-height: 1.65; }

      .proof { list-style: none; display: flex; flex-wrap: wrap; gap: 10px; margin: 30px 0 0; }
      .proof li { font-size: 0.85rem; color: var(--text); background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 8px 14px; }

      .cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 36px; }
      .btn { text-decoration: none; font-weight: 600; font-size: 0.95rem; padding: 13px 26px; border-radius: 10px; transition: transform 0.15s ease, opacity 0.15s ease; }
      .btn:hover { transform: translateY(-2px); }
      .btn--primary { background: var(--accent); color: #04120c; }
      .btn--ghost { background: transparent; color: var(--text); border: 1px solid var(--border); }

      .social { display: flex; gap: 22px; margin-top: 34px; }
      .social a { color: var(--muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; }
      .social a:hover { color: var(--accent); }
    </style>
  </body>
</html>
