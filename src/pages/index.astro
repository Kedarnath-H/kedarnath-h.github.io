---
// ══════════════════════════════════════════════
//  EDIT YOUR TEXT HERE (only change words in quotes)
// ══════════════════════════════════════════════
const name     = "Kedarnath H";
const tagline   = "Financial Analyst · FP&A · Equity Research";
const headline  = "I turn financial data into clear, defensible decisions.";
const subhead   = "MBA in Finance · SEBI NISM certified. I build valuation models, equity research, and Power BI dashboards that turn raw data into decisions leaders can act on.";
const proof     = ["10-Year Multi-Asset Study", "CAMEL Bank Analysis", "ITC Sell-Side Initiation"];
const email     = "kedarnathgshm@gmail.com";
const github     = "https://github.com/Kedarnath-H";
const linkedin   = "https://www.linkedin.com/in/mrkedar";

const resumeReady = false;          // ← change to true AFTER you upload resume.pdf
const resumeFile  = "/resume.pdf";

// ---- YOUR PROJECTS (edit text / add links here) ----
const projects = [
  {
    title: "10-Year Multi-Asset Comparative Study",
    metric: "2,500+",
    metricLabel: "daily observations analysed per asset",
    problem: "Retail investors rarely get a rigorous, like-for-like comparison of equity, gold, and an active fund across a full market cycle.",
    approach: "Cleaned the data with Hampel filtering, then computed CAGR, rolling returns, Sharpe, beta, correlation and maximum drawdown — plus SIP vs lumpsum outcomes and lognormal scenarios to 2034.",
    result: "A 14-sheet decision workbook and Power BI dashboard quantifying the risk-adjusted trade-offs; scenario modeling flagged gold breaking above its 90th-percentile projection band.",
    tools: ["Advanced Excel", "Power BI", "Risk & Return Analytics"],
    github: "https://github.com/Kedarnath-H/sensex-gold-hdfc-flexicap-analysis",
    report: "",
  },
  {
    title: "CAMEL Analysis — Vikas Souharda Co-op Bank",
    metric: "9.3%",
    metricLabel: "RBI-assessed NPA vs 1.83% reported (FY23)",
    problem: "Judge a co-operative bank's real financial health across FY2021–FY2025, beyond the headline numbers in its annual reports.",
    approach: "Scored Capital adequacy, Asset quality, Management efficiency, Earnings and Liquidity from primary filings into a formula-driven Excel model, with a dedicated stress-test tab.",
    result: "Surfaced a material asset-quality gap between reported and RBI-assessed NPAs — the kind of divergence that changes a credit view.",
    tools: ["Financial Statement Analysis", "Advanced Excel", "Power BI"],
    github: "https://github.com/Kedarnath-H/CAMEL-model-analysis",
    report: "",
  },
  {
    title: "ITC Ltd. — Sell-Side Initiation",
    metric: "₹325",
    metricLabel: "DCF target price · BUY rating",
    problem: "Is ITC (NSE: ITC) a buy at current levels, and what intrinsic value can actually be defended?",
    approach: "Built a full initiation as an interactive single-page report — segment analysis, a DCF with a live sensitivity heatmap, and a Beginner/Pro reading toggle for different audiences.",
    result: "A BUY thesis triangulated against primary exchange filings and shareholding data.",
    tools: ["DCF Valuation", "Equity Research", "Financial Modeling"],
    github: "",
    report: "",   // ← we'll fill this next (host the ITC report, then paste its link)
  },
];
// ══════════════════════════════════════════════
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{name} — {tagline}</title>
    <meta name="description" content={subhead} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main class="hero">
      <div class="hero__inner">
        <span class="status"><span class="dot"></span>Open to Financial Analyst / FP&A roles</span>
        <p class="tagline">{tagline}</p>
        <h1 class="name">{name}</h1>
        <h2 class="headline">{headline}</h2>
        <p class="subhead">{subhead}</p>

        <ul class="proof">
          {proof.map((p) => <li>{p}</li>)}
        </ul>

        <div class="cta">
          <a class="btn btn--primary" href="#work">View my work</a>
          {resumeReady && <a class="btn btn--ghost" href={resumeFile} target="_blank" rel="noopener">Download Resume</a>}
          <a class="btn btn--ghost" href={`mailto:${email}`}>Get in touch</a>
        </div>

        <div class="social">
          <a href={linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={github} target="_blank" rel="noopener">GitHub</a>
          <a href={`mailto:${email}`}>Email</a>
        </div>
      </div>
    </main>

    <section id="work" class="work">
      <div class="work__inner">
        <header class="work__head">
          <p class="tagline">Selected Work</p>
          <h2 class="work__title">Analysis that holds up to scrutiny</h2>
          <p class="work__sub">Three projects that show how I move from raw data to a decision I can defend.</p>
        </header>

        <div class="grid">
          {projects.map((proj) => (
            <article class="card">
              <div class="stat">
                <span class="stat__num">{proj.metric}</span>
                <span class="stat__label">{proj.metricLabel}</span>
              </div>
              <h3 class="card__title">{proj.title}</h3>
              <div class="card__body">
                <p><span class="label">Problem</span>{proj.problem}</p>
                <p><span class="label">Approach</span>{proj.approach}</p>
                <p><span class="label result">Result</span>{proj.result}</p>
              </div>
              <ul class="tools">
                {proj.tools.map((t) => <li>{t}</li>)}
              </ul>
              {(proj.github || proj.report) && (
                <div class="card__links">
                  {proj.github && <a href={proj.github} target="_blank" rel="noopener">GitHub →</a>}
                  {proj.report && <a href={proj.report} target="_blank" rel="noopener">Read report →</a>}
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <style>
      /* ---- DESIGN TOKENS (single source of colour/type) ---- */
      :root {
        --bg:        #0a0e1a;
        --surface:   #111827;
        --text:      #f8fafc;
        --muted:     #94a3b8;
        --accent:    #10b981;   /* emerald = positive */
        --negative:  #ef4444;   /* red = negative only */
        --border:    rgba(255,255,255,0.08);
        --font:      'Inter', system-ui, sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body { font-family: var(--font); color: var(--text); background: var(--bg); -webkit-font-smoothing: antialiased; }

      /* ---- HERO ---- */
      .hero {
        min-height: 100vh; display: grid; place-items: center; padding: 6vh 6vw;
        background: radial-gradient(70% 55% at 50% 0%, rgba(16,185,129,0.10), transparent 70%), var(--bg);
      }
      .hero__inner { max-width: 760px; animation: rise 0.7s ease both; }
      @keyframes rise { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }

      .status { display: inline-flex; align-items: center; gap: 8px; font-size: 0.82rem; font-weight: 500; color: var(--muted); border: 1px solid var(--border); border-radius: 999px; padding: 6px 14px; margin-bottom: 28px; }
      .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 4px rgba(16,185,129,0.15); }

      .tagline { color: var(--accent); font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; font-size: 0.8rem; margin-bottom: 14px; }
      .name { font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.05; }
      .headline { font-size: clamp(1.15rem, 2.6vw, 1.7rem); font-weight: 600; color: var(--text); margin: 18px 0 0; line-height: 1.3; }
      .subhead { font-size: clamp(1rem, 1.6vw, 1.12rem); color: var(--muted); margin-top: 20px; max-width: 620px; line-height: 1.65; }

      .proof { list-style: none; display: flex; flex-wrap: wrap; gap: 10px; margin: 30px 0 0; }
      .proof li { font-size: 0.85rem; color: var(--text); background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 8px 14px; }

      .cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 36px; }
      .btn { text-decoration: none; font-weight: 600; font-size: 0.95rem; padding: 13px 26px; border-radius: 10px; transition: transform 0.15s ease, opacity 0.15s ease; }
      .btn:hover { transform: translateY(-2px); }
      .btn--primary { background: var(--accent); color: #04120c; }
      .btn--ghost { background: transparent; color: var(--text); border: 1px solid var(--border); }

      .social { display: flex; gap: 22px; margin-top: 34px; }
      .social a { color: var(--muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; }
      .social a:hover { color: var(--accent); }

      /* ---- WORK ---- */
      .work { padding: 8vh 6vw; max-width: 1120px; margin: 0 auto; }
      .work__head { max-width: 640px; margin-bottom: 48px; }
      .work__title { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; letter-spacing: -0.02em; margin-top: 6px; }
      .work__sub { color: var(--muted); margin-top: 14px; font-size: 1.05rem; line-height: 1.6; }

      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 22px; }
      .card {
        background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 28px;
        display: flex; flex-direction: column; position: relative; overflow: hidden;
        transition: transform 0.2s ease, border-color 0.2s ease;
      }
      .card::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 3px; background: linear-gradient(90deg, var(--accent), transparent); opacity: 0; transition: opacity 0.2s ease; }
      .card:hover { transform: translateY(-4px); border-color: rgba(16,185,129,0.4); }
      .card:hover::before { opacity: 1; }

      .stat { border-left: 3px solid var(--accent); padding-left: 14px; margin-bottom: 20px; }
      .stat__num { display: block; font-size: 2.1rem; font-weight: 800; letter-spacing: -0.02em; color: var(--accent); line-height: 1; }
      .stat__label { display: block; font-size: 0.78rem; color: var(--muted); margin-top: 6px; line-height: 1.4; }

      .card__title { font-size: 1.15rem; font-weight: 700; line-height: 1.3; }
      .card__body { margin: 16px 0 20px; display: flex; flex-direction: column; gap: 14px; }
      .card__body p { font-size: 0.92rem; color: var(--muted); line-height: 1.6; }
      .label { display: block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text); margin-bottom: 4px; }
      .label.result { color: var(--accent); }

      .tools { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; margin-top: auto; }
      .tools li { font-size: 0.75rem; color: var(--muted); border: 1px solid var(--border); border-radius: 6px; padding: 5px 10px; }

      .card__links { display: flex; gap: 18px; margin-top: 20px; padding-top: 18px; border-top: 1px solid var(--border); }
      .card__links a { color: var(--accent); text-decoration: none; font-size: 0.88rem; font-weight: 600; }
      .card__links a:hover { text-decoration: underline; }

      @media (max-width: 520px) { .grid { grid-template-columns: 1fr; } }
    </style>
  </body>
</html>
