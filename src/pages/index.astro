---
// ══════════════════════════════════════════════
//  EDIT YOUR TEXT HERE (only change words in quotes)
// ══════════════════════════════════════════════
const name     = "Kedarnath H";
const tagline   = "Financial Analyst · FP&A · Equity Research";
const headline  = "I turn financial data into clear, defensible decisions.";
const subhead   = "MBA in Finance · SEBI NISM certified. I build valuation models, equity research, and Power BI dashboards that turn raw data into decisions leaders can act on.";
const proof     = ["10-Year Multi-Asset Study", "CAMEL Bank Analysis", "ITC Sell-Side Initiation"];
const email     = "kedarnathgshm@gmail.com";
const github     = "https://github.com/Kedarnath-H";
const linkedin   = "https://www.linkedin.com/in/mrkedar";
const location   = "Bengaluru, India";

const resumeReady = false;          // ← change to true AFTER you upload resume.pdf
const resumeFile  = "/resume.pdf";

// ---- ABOUT ----
const aboutPara = [
  "I work on the questions that sit underneath a number: what it measures, what it leaves out, and whether it survives a second look. Most of my projects started as an attempt to check something I had been told was true.",
  "That habit produced the work on this site. A co-operative bank's reported asset quality did not match the regulator's assessment. An asset that most portfolios treat as a hedge outperformed its own projection band. A large-cap consumer name looked fully priced until the cash flows were modelled properly.",
  "I am looking for a role where that kind of scrutiny is the job — financial analysis, FP&A, or equity research. I work primarily in Excel, Power BI and SQL, and I write up findings so that someone who was not in the spreadsheet can still act on them.",
];

const education = [
  { period: "2023 — 2025", title: "MBA, Finance", org: "AIMS Institutes · Bangalore University" },
  { period: "2025",        title: "SEBI NISM Certification — 94%", org: "Securities market regulation & operations" },
  { period: "2020 — 2023", title: "B.Com, Accounting & Banking", org: "Bangalore University" },
];

const skills = [
  { group: "Analysis & Valuation", items: ["DCF Valuation", "Financial Statement Analysis", "Ratio & CAMEL Analysis", "Risk & Return Metrics", "Forecasting & Scenario Modeling"] },
  { group: "Tools",                items: ["Advanced Excel", "Power BI (DAX, Power Query)", "SQL", "Python (basic)"] },
  { group: "Reporting",            items: ["Equity Research Writing", "Executive Dashboards", "Data Visualization", "Data Cleaning"] },
];

// ---- YOUR PROJECTS ----
const projects = [
  {
    title: "10-Year Multi-Asset Comparative Study",
    metric: "2,500+",
    metricLabel: "daily observations analysed per asset",
    problem: "Retail investors rarely get a rigorous, like-for-like comparison of equity, gold, and an active fund across a full market cycle.",
    approach: "Cleaned the data with Hampel filtering, then computed CAGR, rolling returns, Sharpe, beta, correlation and maximum drawdown — plus SIP vs lumpsum outcomes and lognormal scenarios to 2034.",
    result: "A 14-sheet decision workbook and Power BI dashboard quantifying the risk-adjusted trade-offs; scenario modeling flagged gold breaking above its 90th-percentile projection band.",
    tools: ["Advanced Excel", "Power BI", "Risk & Return Analytics"],
    github: "https://github.com/Kedarnath-H/sensex-gold-hdfc-flexicap-analysis",
    report: "",
  },
  {
    title: "CAMEL Analysis — Vikas Souharda Co-op Bank",
    metric: "9.3%",
    metricLabel: "RBI-assessed NPA vs 1.83% reported (FY23)",
    problem: "Judge a co-operative bank's real financial health across FY2021–FY2025, beyond the headline numbers in its annual reports.",
    approach: "Scored Capital adequacy, Asset quality, Management efficiency, Earnings and Liquidity from primary filings into a formula-driven Excel model, with a dedicated stress-test tab.",
    result: "Surfaced a material asset-quality gap between reported and RBI-assessed NPAs — the kind of divergence that changes a credit view.",
    tools: ["Financial Statement Analysis", "Advanced Excel", "Power BI"],
    github: "https://github.com/Kedarnath-H/CAMEL-model-analysis",
    report: "",
  },
  {
    title: "ITC Ltd. — Sell-Side Initiation",
    metric: "₹325",
    metricLabel: "DCF target price · BUY rating",
    problem: "Is ITC (NSE: ITC) a buy at current levels, and what intrinsic value can actually be defended?",
    approach: "Built a full initiation as an interactive single-page report — segment analysis, a DCF with a live sensitivity heatmap, and a Beginner/Pro reading toggle for different audiences.",
    result: "A BUY thesis triangulated against primary exchange filings and shareholding data.",
    tools: ["DCF Valuation", "Equity Research", "Financial Modeling"],
    github: "",
    report: "/ITC_Report.html",
  },
];
// ══════════════════════════════════════════════
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{name} — {tagline}</title>
    <meta name="description" content={subhead} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <nav class="nav">
      <a href="#top" class="nav__brand">{name}</a>
      <div class="nav__links">
        <a href="#work">Work</a>
        <a href="#about">About</a>
        <a href="#contact">Contact</a>
        {resumeReady && <a href={resumeFile} target="_blank" rel="noopener">Resume</a>}
        <a class="nav__cta" href={`mailto:${email}`}>Email me</a>
      </div>
    </nav>

    <main id="top" class="hero">
      <div class="hero__inner">
        <span class="status"><span class="dot"></span>Open to Financial Analyst / FP&A roles</span>
        <p class="tagline">{tagline}</p>
        <h1 class="name">{name}</h1>
        <h2 class="headline">{headline}</h2>
        <p class="subhead">{subhead}</p>

        <ul class="proof">
          {proof.map((p) => <li>{p}</li>)}
        </ul>

        <div class="cta">
          <a class="btn btn--primary" href="#work">View my work</a>
          {resumeReady && <a class="btn btn--ghost" href={resumeFile} target="_blank" rel="noopener">Download Resume</a>}
          <a class="btn btn--ghost" href="#contact">Get in touch</a>
        </div>

        <div class="social">
          <a href={linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href={github} target="_blank" rel="noopener">GitHub</a>
          <a href={`mailto:${email}`}>Email</a>
        </div>
      </div>
    </main>

    <section id="work" class="work">
      <div class="work__inner">
        <header class="work__head">
          <p class="tagline">Selected Work</p>
          <h2 class="work__title">Analysis that holds up to scrutiny</h2>
          <p class="work__sub">Three projects that show how I move from raw data to a decision I can defend.</p>
        </header>

        <div class="grid">
          {projects.map((proj) => (
            <article class="card">
              <div class="stat">
                <span class="stat__num">{proj.metric}</span>
                <span class="stat__label">{proj.metricLabel}</span>
              </div>
              <h3 class="card__title">{proj.title}</h3>
              <div class="card__body">
                <p><span class="label">Problem</span>{proj.problem}</p>
                <p><span class="label">Approach</span>{proj.approach}</p>
                <p><span class="label result">Result</span>{proj.result}</p>
              </div>
              <ul class="tools">
                {proj.tools.map((t) => <li>{t}</li>)}
              </ul>
              {(proj.github || proj.report) && (
                <div class="card__links">
                  {proj.github && <a href={proj.github} target="_blank" rel="noopener">GitHub →</a>}
                  {proj.report && <a href={proj.report} target="_blank" rel="noopener">Read report →</a>}
                </div>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="about" class="about">
      <div class="about__inner">
        <div class="about__col">
          <p class="tagline">About</p>
          <h2 class="about__title">Numbers first. Conclusions second.</h2>
          {aboutPara.map((p) => <p class="about__text">{p}</p>)}
        </div>

        <aside class="about__side">
          <h3 class="side__head">Education & Certification</h3>
          <ul class="timeline">
            {education.map((e) => (
              <li class="timeline__item">
                <span class="timeline__period">{e.period}</span>
                <span class="timeline__title">{e.title}</span>
                <span class="timeline__org">{e.org}</span>
              </li>
            ))}
          </ul>
        </aside>
      </div>

      <div class="skills">
        <h3 class="side__head">Skills</h3>
        <div class="skills__grid">
          {skills.map((s) => (
            <div class="skills__group">
              <h4 class="skills__label">{s.group}</h4>
              <ul class="skills__list">
                {s.items.map((i) => <li>{i}</li>)}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section id="contact" class="contact">
      <div class="contact__inner">
        <p class="tagline">Contact</p>
        <h2 class="contact__title">Let's talk analysis.</h2>
        <p class="contact__sub">Open to Financial Analyst, FP&A and Equity Research roles. Based in {location} — happy to connect remotely or on-site.</p>

        <div class="contact__actions">
          <a class="btn btn--primary" href={`mailto:${email}`}>Email me</a>
          <a class="btn btn--ghost" href={linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a class="btn btn--ghost" href={github} target="_blank" rel="noopener">GitHub</a>
        </div>

        <p class="contact__email">{email}</p>
      </div>
    </section>

    <footer class="footer">
      <span>© {new Date().getFullYear()} {name}</span>
      <span class="footer__note">Built with Astro · Hosted on GitHub Pages</span>
    </footer>

    <style>
      /* ---- DESIGN TOKENS ---- */
      :root {
        --bg:        #0a0e1a;
        --surface:   #111827;
        --text:      #f8fafc;
        --muted:     #94a3b8;
        --accent:    #10b981;
        --negative:  #ef4444;
        --border:    rgba(255,255,255,0.08);
        --font:      'Inter', system-ui, sans-serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; scroll-padding-top: 70px; }
      body { font-family: var(--font); color: var(--text); background: var(--bg); -webkit-font-smoothing: antialiased; }

      /* ---- NAV ---- */
      .nav {
        position: sticky; top: 0; z-index: 50;
        display: flex; justify-content: space-between; align-items: center;
        padding: 14px 6vw;
        background: rgba(10,14,26,0.72); backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .nav__brand { color: var(--text); text-decoration: none; font-weight: 700; font-size: 0.98rem; letter-spacing: -0.01em; }
      .nav__links { display: flex; align-items: center; gap: 6px; }
      .nav__links a { color: var(--muted); text-decoration: none; font-size: 0.88rem; font-weight: 500; padding: 8px 12px; border-radius: 8px; transition: color 0.15s ease; }
      .nav__links a:hover { color: var(--text); }
      .nav__cta { color: #04120c !important; background: var(--accent); font-weight: 600 !important; }
      .nav__cta:hover { opacity: 0.9; }

      /* ---- HERO ---- */
      .hero {
        min-height: calc(100vh - 60px); display: grid; place-items: center; padding: 6vh 6vw;
        background: radial-gradient(70% 55% at 50% 0%, rgba(16,185,129,0.10), transparent 70%), var(--bg);
      }
      .hero__inner { max-width: 760px; animation: rise 0.7s ease both; }
      @keyframes rise { from { opacity: 0; transform: translateY(14px); } to { opacity: 1; transform: none; } }

      .status { display: inline-flex; align-items: center; gap: 8px; font-size: 0.82rem; font-weight: 500; color: var(--muted); border: 1px solid var(--border); border-radius: 999px; padding: 6px 14px; margin-bottom: 28px; }
      .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); box-shadow: 0 0 0 4px rgba(16,185,129,0.15); }

      .tagline { color: var(--accent); font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase; font-size: 0.8rem; margin-bottom: 14px; }
      .name { font-size: clamp(2.4rem, 6vw, 4rem); font-weight: 800; letter-spacing: -0.02em; line-height: 1.05; }
      .headline { font-size: clamp(1.15rem, 2.6vw, 1.7rem); font-weight: 600; margin: 18px 0 0; line-height: 1.3; }
      .subhead { font-size: clamp(1rem, 1.6vw, 1.12rem); color: var(--muted); margin-top: 20px; max-width: 620px; line-height: 1.65; }

      .proof { list-style: none; display: flex; flex-wrap: wrap; gap: 10px; margin: 30px 0 0; }
      .proof li { font-size: 0.85rem; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 8px 14px; }

      .cta { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 36px; }
      .btn { text-decoration: none; font-weight: 600; font-size: 0.95rem; padding: 13px 26px; border-radius: 10px; transition: transform 0.15s ease, opacity 0.15s ease; }
      .btn:hover { transform: translateY(-2px); }
      .btn--primary { background: var(--accent); color: #04120c; }
      .btn--ghost { background: transparent; color: var(--text); border: 1px solid var(--border); }

      .social { display: flex; gap: 22px; margin-top: 34px; }
      .social a { color: var(--muted); text-decoration: none; font-size: 0.9rem; font-weight: 500; }
      .social a:hover { color: var(--accent); }

      /* ---- WORK ---- */
      .work { padding: 8vh 6vw; max-width: 1120px; margin: 0 auto; }
      .work__head { max-width: 640px; margin-bottom: 48px; }
      .work__title { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; letter-spacing: -0.02em; margin-top: 6px; }
      .work__sub { color: var(--muted); margin-top: 14px; font-size: 1.05rem; line-height: 1.6; }

      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 22px; }
      .card {
        background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 28px;
        display: flex; flex-direction: column; position: relative; overflow: hidden;
        transition: transform 0.2s ease, border-color 0.2s ease;
      }
      .card::before { content: ""; position: absolute; inset: 0 0 auto 0; height: 3px; background: linear-gradient(90deg, var(--accent), transparent); opacity: 0; transition: opacity 0.2s ease; }
      .card:hover { transform: translateY(-4px); border-color: rgba(16,185,129,0.4); }
      .card:hover::before { opacity: 1; }

      .stat { border-left: 3px solid var(--accent); padding-left: 14px; margin-bottom: 20px; }
      .stat__num { display: block; font-size: 2.1rem; font-weight: 800; letter-spacing: -0.02em; color: var(--accent); line-height: 1; }
      .stat__label { display: block; font-size: 0.78rem; color: var(--muted); margin-top: 6px; line-height: 1.4; }

      .card__title { font-size: 1.15rem; font-weight: 700; line-height: 1.3; }
      .card__body { margin: 16px 0 20px; display: flex; flex-direction: column; gap: 14px; }
      .card__body p { font-size: 0.92rem; color: var(--muted); line-height: 1.6; }
      .label { display: block; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text); margin-bottom: 4px; }
      .label.result { color: var(--accent); }

      .tools { list-style: none; display: flex; flex-wrap: wrap; gap: 8px; margin-top: auto; }
      .tools li { font-size: 0.75rem; color: var(--muted); border: 1px solid var(--border); border-radius: 6px; padding: 5px 10px; }

      .card__links { display: flex; gap: 18px; margin-top: 20px; padding-top: 18px; border-top: 1px solid var(--border); }
      .card__links a { color: var(--accent); text-decoration: none; font-size: 0.88rem; font-weight: 600; }
      .card__links a:hover { text-decoration: underline; }

      /* ---- ABOUT ---- */
      .about { padding: 6vh 6vw 10vh; max-width: 1120px; margin: 0 auto; border-top: 1px solid var(--border); }
      .about__inner { display: grid; grid-template-columns: 1.6fr 1fr; gap: 60px; align-items: start; }
      .about__title { font-size: clamp(1.8rem, 4vw, 2.6rem); font-weight: 800; letter-spacing: -0.02em; margin-top: 6px; }
      .about__text { color: var(--muted); font-size: 1.02rem; line-height: 1.75; margin-top: 20px; }

      .side__head { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text); margin-bottom: 22px; }
      .about__side { padding-top: 8px; }
      .timeline { list-style: none; display: flex; flex-direction: column; gap: 24px; }
      .timeline__item { border-left: 2px solid var(--border); padding-left: 18px; display: flex; flex-direction: column; gap: 4px; }
      .timeline__period { font-size: 0.75rem; color: var(--accent); font-weight: 600; letter-spacing: 0.03em; }
      .timeline__title { font-size: 0.95rem; font-weight: 600; }
      .timeline__org { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }

      .skills { margin-top: 70px; padding-top: 46px; border-top: 1px solid var(--border); }
      .skills__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 32px; }
      .skills__label { font-size: 0.9rem; font-weight: 700; color: var(--accent); margin-bottom: 14px; }
      .skills__list { list-style: none; display: flex; flex-direction: column; gap: 9px; }
      .skills__list li { font-size: 0.92rem; color: var(--muted); }

      /* ---- CONTACT ---- */
      .contact {
        padding: 10vh 6vw; text-align: center;
        background: radial-gradient(60% 60% at 50% 100%, rgba(16,185,129,0.08), transparent 70%), var(--bg);
        border-top: 1px solid var(--border);
      }
      .contact__inner { max-width: 640px; margin: 0 auto; }
      .contact__title { font-size: clamp(1.9rem, 4.5vw, 2.8rem); font-weight: 800; letter-spacing: -0.02em; margin-top: 6px; }
      .contact__sub { color: var(--muted); margin-top: 16px; font-size: 1.05rem; line-height: 1.65; }
      .contact__actions { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-top: 34px; }
      .contact__email { color: var(--muted); margin-top: 28px; font-size: 0.9rem; }

      /* ---- FOOTER ---- */
      .footer {
        padding: 30px 6vw; display: flex; flex-wrap: wrap; gap: 8px;
        justify-content: space-between; align-items: center;
        border-top: 1px solid var(--border); color: var(--muted); font-size: 0.82rem;
      }
      .footer__note { opacity: 0.7; }

      @media (max-width: 860px) {
        .about__inner { grid-template-columns: 1fr; gap: 46px; }
      }
      @media (max-width: 600px) {
        .nav__brand { display: none; }
        .nav { justify-content: center; }
        .nav__links a { padding: 8px 9px; font-size: 0.84rem; }
      }
      @media (max-width: 520px) {
        .grid { grid-template-columns: 1fr; }
        .footer { justify-content: center; text-align: center; }
      }
    </style>

    <script is:inline defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "db2200e94fa4486fb0ed8923c8ccfddb"}'></script>
  </body>
</html>
